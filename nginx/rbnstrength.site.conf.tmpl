server {
    listen 80;
    server_name __STRENGTH_DOMAIN__;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}
server {
    listen 443 ssl http2;
    server_name __STRENGTH_DOMAIN__;
    ssl_certificate     /etc/letsencrypt/live/__STRENGTH_DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/__STRENGTH_DOMAIN__/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header Service-Worker-Allowed "/";
    location / {
        proxy_pass         http://rbnstrength:3002;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
