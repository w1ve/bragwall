# в”Ђв”Ђ HTTP вЂ” redirect to HTTPS + ACME challenge в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
server {
    listen 80;
    server_name __DOMAIN__;

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# в”Ђв”Ђ HTTPS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
server {
    listen 443 ssl http2;
    server_name __DOMAIN__;

    ssl_certificate     /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header Service-Worker-Allowed "/";

    root  /usr/share/nginx/html;
    index index.html;

    # в”Ђв”Ђ Node proxy routes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    location /rbn {
        proxy_pass         http://127.0.0.1:3001/rbn;
        proxy_http_version 1.1;
        proxy_read_timeout 15s;
        proxy_connect_timeout 5s;
    }

    location /hamdb/ {
        proxy_pass         http://127.0.0.1:3001/hamdb/;
        proxy_http_version 1.1;
        proxy_read_timeout 10s;
        proxy_connect_timeout 5s;
    }

    location /solar {
        proxy_pass         http://127.0.0.1:3001/solar;
        proxy_http_version 1.1;
        proxy_read_timeout 20s;
        proxy_connect_timeout 5s;
    }

    location /psk {
        proxy_pass         http://127.0.0.1:3001/psk;
        proxy_http_version 1.1;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
    }

    location /audio/ {
        proxy_pass         http://127.0.0.1:3001/audio/;
        proxy_http_version 1.1;
        proxy_read_timeout 60s;
        proxy_connect_timeout 5s;
    }

    location /health {
        proxy_pass http://127.0.0.1:3001/health;
        proxy_http_version 1.1;
    }

    location /gridinfo {
        proxy_pass         http://127.0.0.1:3001/gridinfo;
        proxy_http_version 1.1;
        proxy_read_timeout 10s;
        proxy_connect_timeout 5s;
    }

    location /vantage {
        proxy_pass         http://127.0.0.1:3001/vantage;
        proxy_http_version 1.1;
        proxy_read_timeout 5s;
        proxy_connect_timeout 3s;
    }

    location /history {
        proxy_pass         http://127.0.0.1:3001/history;
        proxy_http_version 1.1;
        proxy_read_timeout 10s;
        proxy_connect_timeout 5s;
        add_header Cache-Control "no-cache";
    }

    # в”Ђв”Ђ Badge image API в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    location /badge/ {
        proxy_pass         http://rbn-badge:3002/badge/;
        proxy_http_version 1.1;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
        proxy_cache_bypass $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        proxy_no_cache     $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        add_header Cache-Control "no-cache";
        add_header Access-Control-Allow-Origin "*";
    }
    location /badges/ {
        proxy_pass         http://rbn-badge:3002/badges/;
        proxy_http_version 1.1;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
        proxy_cache_bypass $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        proxy_no_cache     $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        add_header Cache-Control "no-cache";
        add_header Access-Control-Allow-Origin "*";
    }
    # Alias endpoints for new branding (backward compatible with /badge/*)
    location /hfsignals/ {
        proxy_pass         http://rbn-badge:3002/hfsignals/;
        proxy_http_version 1.1;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
        proxy_cache_bypass $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        proxy_no_cache     $arg_theme$arg__t$arg_from$arg_to$arg_grid$arg_radius;
        add_header Cache-Control "no-cache";
        add_header Access-Control-Allow-Origin "*";
    }

    location /historymap {
        proxy_pass         http://rbn-badge:3002/historymap;
        proxy_http_version 1.1;
        proxy_read_timeout 30s;
        proxy_connect_timeout 5s;
        proxy_cache_bypass $arg_theme$arg__t$arg_vantage$arg_size;
        proxy_no_cache     $arg_theme$arg__t$arg_vantage$arg_size;
        add_header Cache-Control "no-cache";
        add_header Access-Control-Allow-Origin "*";
    }

    # в”Ђв”Ђ API docs page в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    location = /api {
        rewrite ^ /api.html break;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # в”Ђв”Ђ Service worker + app shell вЂ” never HTTP-cached в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    location ~* ^/(sw\.js|app\.js|style\.css|index\.html|manifest\.json)$ {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Service-Worker-Allowed "/";
    }

    # в”Ђв”Ђ Other static assets (icons etc.) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    # Note: .png intentionally excluded вЂ” badge routes return dynamic PNGs and
    # have their own Cache-Control: no-cache headers set in the /badge/ block above.
    # Static app icons (icon-192.png etc.) are served with the default no-cache
    # from the catch-all location / block, which is acceptable.
    location ~* \.(ico|webp)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    location ~ /\. { deny all; }
}
